# ============================================
# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Firebase credentials (NEVER commit these)
*firebase*.json
*-firebase-adminsdk*.json
firebase-credentials*.json

# Credentials directories
credentials/
secrets/
private/

# Sensitive configuration
secrets.json

# ============================================
