# hna-acadex-backend/.env.example
# Development Environment Variables
# Copy this file to .env for local development

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=1
# Allow connections from localhost and Android emulator (10.0.2.2)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2
DJANGO_LOG_LEVEL=INFO
CORE_LOG_LEVEL=DEBUG
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=180
AUTH_COOKIE_USE_SESSION=1
# Optional: set to 1 only for build-time management commands (collectstatic/migrate)
# SKIP_PRODUCTION_ENV_VALIDATION=1

# Database (SQLite for local development)
# For production on Render, DATABASE_URL is set automatically
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CORS Settings - Use specific origins (required for credentials: 'include')
# IMPORTANT: CORS_ALLOW_ALL_ORIGINS=1 is incompatible with credentials
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://10.0.2.2:8081,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000

# Email Settings (for sending credentials to teachers/students)
# ============================================
# EMAIL_BACKEND_TYPE: Toggle between Brevo API and SMTP
# - 'brevo' (default): Uses Brevo's Transactional Email API (recommended for production)
# - 'smtp': Uses Gmail SMTP (useful for development/testing)
# ============================================
EMAIL_BACKEND_TYPE=smtp

# Gmail SMTP Settings (used when EMAIL_BACKEND_TYPE=smtp)
# Setup: Enable 2FA on Google Account, then generate App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=hnaacadexadmin@gmail.com
EMAIL_HOST_PASSWORD="your-app-password"
DEFAULT_FROM_EMAIL=hnaacadexadmin@gmail.com

# Brevo API Settings (used when EMAIL_BACKEND_TYPE=brevo)
# Get your API key from: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=your-brevo-api-key

# Frontend URL (for links in emails)
FRONTEND_URL=http://localhost:8081

# ============================================
# CELERY SETTINGS (for background tasks)
# ============================================
# Redis is used as the message broker for Celery
# For local development, install and run Redis locally
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# For managed Redis with TLS (e.g. Upstash), use rediss:// URLs
# CELERY_BROKER_URL=rediss://default:password@host:port/0
# CELERY_RESULT_BACKEND=rediss://default:password@host:port/0

# ============================================
# FIREBASE SETTINGS (for push notifications)
# ============================================
# Option 1: Path to your Firebase Admin SDK credentials JSON file (local dev)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./hna-acadex-firebase-adminsdk.json

# Option 2: JSON string of credentials (production - Render dashboard)
# Copy the entire JSON content and set as FIREBASE_CREDENTIALS_JSON
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ============================================
# PRODUCTION SETTINGS (for Render deployment)
# ============================================
# Set these in Render Dashboard > Environment:
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=<generated>
# DJANGO_ALLOWED_HOSTS=.onrender.com
# CORS_ALLOW_ALL_ORIGINS=0
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.onrender.com
# FRONTEND_URL=https://your-frontend.vercel.app
# DJANGO_LOG_LEVEL=INFO
# CORE_LOG_LEVEL=INFO
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_TOKEN_DAYS=180
# AUTH_COOKIE_USE_SESSION=1
# EMAIL_BACKEND_TYPE=brevo
# BREVO_API_KEY=<your-brevo-api-key>
# EMAIL_HOST_PASSWORD=<your-app-password>  (only if using smtp backend)
# FIREBASE_CREDENTIALS_JSON=<firebase-json-string>
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# PRODUCTION SETTINGS (Koyeb + Neon free stack)
# ============================================
# Build command: ./koyeb-build.sh
# Run command: ./start.sh
# Health check path: /healthz/
#
# Required:
# DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=<strong-secret>
# DJANGO_ALLOWED_HOSTS=.koyeb.app,<your-custom-domain>
# CORS_ALLOW_ALL_ORIGINS=0
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.koyeb.app
# FRONTEND_URL=https://your-frontend.vercel.app
