# hna-acadex-backend/.env.example
# Development Environment Variables
# Copy this file to .env for local development

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=1
# Allow connections from localhost and Android emulator (10.0.2.2)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2

# Database (SQLite for local development)
# For production on Render, DATABASE_URL is set automatically

# CORS Settings - Allow all origins in development
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://10.0.2.2:8081

# Email Settings (for sending credentials to teachers/students)
# For development, you can use console backend to see emails in terminal:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=hnaacadexadmin@gmail.com
EMAIL_HOST_PASSWORD="your-app-password"
DEFAULT_FROM_EMAIL=hnaacadexadmin@gmail.com

# Frontend URL (for links in emails)
FRONTEND_URL=http://localhost:8081

# ============================================
# CELERY SETTINGS (for background tasks)
# ============================================
# Redis is used as the message broker for Celery
# For local development, install and run Redis locally
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# FIREBASE SETTINGS (for push notifications)
# ============================================
# Option 1: Path to your Firebase Admin SDK credentials JSON file (local dev)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./hna-acadex-firebase-adminsdk.json

# Option 2: JSON string of credentials (production - Render dashboard)
# Copy the entire JSON content and set as FIREBASE_CREDENTIALS_JSON
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ============================================
# PRODUCTION SETTINGS (for Render deployment)
# ============================================
# Set these in Render Dashboard > Environment:
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=<generated>
# DJANGO_ALLOWED_HOSTS=.onrender.com
# CORS_ALLOW_ALL_ORIGINS=0
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# FRONTEND_URL=https://your-frontend.vercel.app
# EMAIL_HOST_PASSWORD=<your-app-password>
# FIREBASE_CREDENTIALS_JSON=<firebase-json-string>
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0